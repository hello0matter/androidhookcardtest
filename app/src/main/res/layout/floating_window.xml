<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@drawable/floating_window_background"
    android:id="@+id/floating_root_view" >

    <!-- The drag handle remains semi-transparent white, which is fine -->
    <View
        android:id="@+id/drag_handle"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:background="#44FFFFFF"
        android:layout_marginBottom="8dp"/>

    <!-- To change the SeekBar color, we need to tint its progress and thumb drawables -->
    <SeekBar
        android:id="@+id/seekbar"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:progressTint="@android:color/white"
        android:thumbTint="@android:color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <!-- For the EditText, we change the text color and hint text color -->
        <EditText
            android:id="@+id/et_delay_seconds"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="输入延迟(秒),如0.15"
            android:inputType="numberDecimal"
            android:textSize="14sp"
            android:maxLines="1"
            android:textColor="@android:color/white"
            android:textColorHint="#CCCCCC" /> <!-- A lighter gray for the hint -->

        <!-- For the Button, we change the text color -->
        <Button
            android:id="@+id/btn_save_delay"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="保存"
            android:textSize="14sp"
            android:layout_marginStart="8dp"
            android:textColor="@android:color/white" />
    </LinearLayout>

</LinearLayout>